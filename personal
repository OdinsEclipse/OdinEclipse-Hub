local function loadGiftClaim(tab, giftName, giftTitle, claimInterval)
    -- Create a section in the specified tab for the gift claim feature
    local section = tab:AddSection("Free Gift")
    
    local autoClaimGift = false
    -- Add a toggle for auto-claiming the gift
    local giftToggle = tab:AddToggle("AutoClaim_" .. giftName, { Title = giftTitle, Default = false })

    giftToggle:OnChanged(function()
        autoClaimGift = giftToggle.Value

        if autoClaimGift then
            print(giftTitle .. " Enabled")
            spawn(function()
                local args = {
                    [1] = giftName
                }
                while autoClaimGift do
                    -- Trigger the server event for claiming the gift
                    local success, message = pcall(function()
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.FreeGiftService.RF.Claim:InvokeServer(unpack(args))
                    end)

                    -- Log success or error
                    if success then
                        print(giftName .. " claimed successfully!")
                    else
