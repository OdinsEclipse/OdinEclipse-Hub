-- Function Definitions
local function loadTeleport(worldTab, worldId)
    local section = worldTab:AddSection("Teleport")
    
    -- Get world name and icon from the WorldNames table
    local worldData = WorldNames[tonumber(worldId)]
    local worldName = worldData and worldData.name or "Unknown"
    local worldIcon = worldData and worldData.icon or "QuestionMark"
    
    worldTab:AddButton({
        Title = "Teleport to " .. worldName,  -- Use the worldName here for the teleport button
        Callback = function()
            local args = {
                workspace.Zones[worldId].Interactables.Teleports.Locations.Spawn
            }
            game:GetService("ReplicatedStorage").Packages.Knit.Services.ZoneService.RE.teleport:FireServer(unpack(args))
        end
    })
end

-- Function to load a specific world
local function loadWorld(worldId)
    if not LoadedWorlds[worldId] then
        -- Get world name and icon from the WorldNames table
        local worldData = WorldNames[tonumber(worldId)]
        local worldName = worldData and worldData.name or "Unknown"
        local worldIcon = worldData and worldData.icon or "QuestionMark"
        
        -- Create the tab dynamically for the world, with the icon first and then the title in the format you want
        local worldTab = Window:AddTab({ 
            Title = "World " .. worldId .. " | " .. worldName,  -- World name after world number
            Icon = worldIcon  -- Icon displayed in the tab
        })
        LoadedWorlds[worldId] = worldTab

        -- Get the eggs for the specific world
        local eggs = WorldEggs[tonumber(worldId)] or {}

        -- Load functionalities for the world
        loadTeleport(worldTab, worldId)
        loadTraining(worldTab, worldId)
        loadAutoNPCBossFighting(worldTab, worldId)
		if worldId == "3" then
			loadAutoTower(worldTab, worldId, "Beach Tower", "BeachTower")
		end
		if worldId == "12" then
			loadAutoSpinWheel(worldTab, worldId, "The Cave's Fortune", "Cave Fortune")
		end
		if worldId == "13" then
			loadAutoOpenChest(worldTab, WorldId, "Kingdom Chest", "KingdomChest")
			loadAutoTrial(worldTab, worldId, "Medieval", "Medieval", 1201)
		end
		if worldId == "14" then
			loadAutoOpenChest(worldTab, worldId, "Orc Vault", "OrcVault")
		end
		if worldId == "15" then
			loadAutoSpinWheel(worldTab, worldId, "Divine Fortune", "Divine Fortune")
			loadAutoTrial(worldTab, worldId, "Angelic", "Angelic", 600)
		end
		if worldId == "16" then
			loadAutoTower(worldTab, worldId, " Rift Cave", "RiftCave")
		end
        if worldId == "17" then
			loadPetCrate(worldTab, "Feeling Lucky? 265% Giga Pet Crate", "Auto Roll Pet Crate", "Cost 1 Matrix Key Per Roll. Roll for a chance of a FREE 265% Giga Pet!", "Matrix")
            loadMerchant(worldTab, worldId, "Matrix Merchant")
        end
		if worldId == "18" then
			loadAutoTower(worldTab, worldId, "Super Wrestle", "SuperWrestle")
		end
        if worldId == "20" then
            loadAutoSpinWheel(worldTab, worldId, "Sakura Fortune", "Sakura Fortune Spinner")
        end
        if worldId == "22" then
            loadAutoTower(worldTab, worldId, "Skull Cave Tower", "SkullCaveTower")
        end
        loadEggHatching(worldTab, worldId, eggs) -- Pass eggs to the egg-hatching functionality
    end
end

