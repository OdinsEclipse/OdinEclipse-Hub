local function loadAutoNPC(worldTab, worldId, npcPath)
    local section = worldTab:AddSection("Auto NPC Farm")

    -- Track state
    local isAutoFarming = false
    local VirtualInputManager = game:GetService("VirtualInputManager")

    -- Function to hold E key with pattern
    local function holdEPattern()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        wait(1.5) -- Hold for 1.5 seconds
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        wait(0.5) -- Release for 0.5 seconds
    end

    -- Auto Beat NPC Toggle
    local AutoBeatNPCToggle = worldTab:AddToggle("AutoBeatNPC", {
        Title = "Auto Beat NPC",
        Description = "Automatically fights NPCs in the given world.",
        Default = false
    })

    AutoBeatNPCToggle:OnChanged(function()
        isAutoFarming = AutoBeatNPCToggle.Value

        if isAutoFarming then
            spawn(function()
                while isAutoFarming do
                    local npcs = npcPath:GetChildren()
                    for _, npc in ipairs(npcs) do
                        if not isAutoFarming then break end
                        
                        -- Ensure the target is an NPC and not a boss
                        if npc:IsA("Model") and npc:FindFirstChild("Table") and 
                           npc.Table:FindFirstChild("PlayerRoot") and not npc.Name:lower():find("boss") then
                            -- Teleport to NPC
                            local player = game.Players.LocalPlayer
                            local character = player.Character
                            local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
                            
                            if humanoidRootPart then
                                -- Teleport the player to the NPC's PlayerRoot
                                humanoidRootPart.CFrame = npc.Table.PlayerRoot.CFrame

                                -- Start E key pattern
                                spawn(function()
                                    local startTime = tick()
                                    while isAutoFarming and (tick() - startTime) < 4 do
                                        holdEPattern()
                                    end
                                end)

                                wait(4) -- Wait 4 seconds before next teleport
                            else
                                print("HumanoidRootPart not found!")
                            end
                        end
                    end
                    wait(0.1) -- Small delay before checking again
                end
            end)
        end
    end)
end

