-- Function to load training for any world
local function loadTraining(worldTab, worldId)
    local trainSection = worldTab:AddSection("Training")

    -- Add Dropdown for selecting training type
    local trainingDropdown = trainSection:AddDropdown("TrainingSelect" .. worldId, {
        Title = "Select Training Type",
        Values = {"Dumbells", "PunchBags", "Grips"},  -- Added "Grips"
        Multi = false,
        Default = "Dumbells"
    })

    -- Add Toggle for enabling/disabling Auto Train
    local autoTrainToggle = trainSection:AddToggle("AutoTrain" .. worldId, {
        Title = "Auto Train",
        Default = false
    })

    autoTrainToggle:OnChanged(function()
        if autoTrainToggle.Value then
            -- Equipment/Position check (10s)
            spawn(function()
                while autoTrainToggle.Value do
                    if trainingDropdown.Value == "Dumbells" then
                        local equipment = GetBestDumbbell(worldId)
                        local args = {
                            [1] = worldId,
                            [2] = "Dumbells",
                            [3] = equipment
                        }
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.ToolService.RE.onGuiEquipRequest:FireServer(unpack(args))
                    elseif trainingDropdown.Value == "Grips" then
                        local grip = GetBestGrip(worldId)
                        local args = {
                            [1] = worldId,
                            [2] = "Grips",
                            [3] = grip
                        }
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.ToolService.RE.onGuiEquipRequest:FireServer(unpack(args))
                    else
                        local tier = GetBestPunchBag(worldId)
                        local bag = workspace.Zones[worldId].Interactables.Training.PunchBags[tier]
                        if bag then
                            local bagCFrame = bag:GetPivot()
                            local teleportPos = bagCFrame * CFrame.new(0, 0, -3)
                            game.Players.LocalPlayer.Character:PivotTo(teleportPos)

                            local args = {
                                [1] = worldId,
                                [2] = tier,
                                [3] = game.Players.LocalPlayer:GetAttribute("VIP") == true
                            }
                            game:GetService("ReplicatedStorage").Packages.Knit.Services.PunchBagService.RE.onGiveStats:FireServer(unpack(args))
                        end
                    end
                    wait(10)
                end
            end)

            -- Stats update (0.25s)
            spawn(function()
                while autoTrainToggle.Value do
                    if trainingDropdown.Value == "Dumbells" then
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.ToolService.RE.onClick:FireServer()
                    elseif trainingDropdown.Value == "Grips" then
                        local grip = GetBestGrip(worldId)
                        local args = {
                            [1] = worldId,
                            [2] = "Grips",
                            [3] = grip
                        }
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.ToolService.RE.onClick:FireServer(unpack(args))
                    else
                        local tier = GetBestPunchBag(worldId)
                        local args = {
                            [1] = worldId,
                            [2] = tier,
                            [3] = game.Players.LocalPlayer:GetAttribute("VIP") == true
                        }
                        game:GetService("ReplicatedStorage").Packages.Knit.Services.PunchBagService.RE.onGiveStats:FireServer(unpack(args))
                    end
                    wait(0.25)
                end
            end)
        end
    end)
end


