-- Function to get the best punch bag for a given world
local function GetBestPunchBag(worldId)
    local player = game.Players.LocalPlayer
    local ninjaKnuckles = player:GetAttribute("KnuckleStrength") or 0  -- Unified for all worlds

    local punchBagData = require(game:GetService("ReplicatedStorage").Data.PunchBags)

    if player:GetAttribute("VIP") == true then
        return "VIP"
    end

    local bestTier = "Tier1"
    local highestRequired = 0

    if punchBagData and punchBagData[worldId] then
        for tier, data in pairs(punchBagData[worldId]) do
            if data.StrengthRequired and 
               ninjaKnuckles >= data.StrengthRequired and 
               data.StrengthRequired > highestRequired then
                bestTier = tier
                highestRequired = data.StrengthRequired
            end
        end
    end

    return bestTier
end

