    for petId, petInfo in pairs(petData) do
        local petUI = player.PlayerGui.GameUI.Menus.Inventory.Display.Pets.ScrollingFrame.Pets:FindFirstChild(tostring(petId))
        if petUI then
            -- Locate or create the lock icon
            local lockToggle = petUI:FindFirstChild("LockIcon", true) or petUI:FindFirstChild("LockPet", true)
            if not lockToggle then
                -- Create the lock icon if it doesn't exist
                lockToggle = Instance.new("ImageLabel")
                lockToggle.Name = "LockIcon"
                lockToggle.Parent = petUI
                lockToggle.Size = UDim2.new(0, 20, 0, 20)  -- Set the size of the lock icon
                lockToggle.Position = UDim2.new(1, -25, 0, 5)  -- Position the icon in the top-right corner of the pet UI
                lockToggle.AnchorPoint = Vector2.new(1, 0)  -- Anchor the icon to the top-right
                lockToggle.BackgroundTransparency = 1  -- Make the background transparent
            end

            -- Update lock icon visibility and image
            if petInfo.Locked then
                lockToggle.ImageTransparency = 0  -- Make the icon visible
                lockToggle.Image = "rbxassetid://13938110841"  -- Lock icon asset ID (replace with your preferred lock icon)
            else
                lockToggle.ImageTransparency = 1  -- Make the icon transparent (hidden)
            end
        else
            warn("Pet UI not found for pet ID:", petId)
        end
    end
end

-- Lock/Unlock all pets
local function updateLockState(lock)
    local petData = getOwnedPets()
    if not petData then
        Fluent:Notify({
            Title = "Error",
            Content = "No pets found to lock/unlock.",
            Duration = 5
        })
        return
    end

    local lockedPets = {}
    for petId, petInfo in pairs(petData) do
        if typeof(petInfo) == "table" then
            if lock and not petInfo.Locked then
                lockedPets[petId] = true
            elseif not lock and petInfo.Locked then
                lockedPets[petId] = false
            end
        end
    end

    if next(lockedPets) == nil then
        Fluent:Notify({
            Title = "No Pets to Lock/Unlock",
            Content = "No pets need to be " .. (lock and "locked" or "unlocked") .. ".",
            Duration = 5
        })
        return
    end

    local success, response = pcall(function()
        return petService.updateLocked:InvokeServer(lockedPets)
    end)

    if success then
        Fluent:Notify({
            Title = "Success",
            Content = lock and "All unlocked pets have been LOCKED!" or "All locked pets have been UNLOCKED!",
            Duration = 5
        })

        wait(1)  -- Give a slight delay before updating the UI
        updateLockIcons()  -- Refresh the UI to reflect the changes
    else
        warn("Failed to update lock state:", response)
        Fluent:Notify({
            Title = "Error",
            Content = "Failed to update lock state.",
            Duration = 5
        })
    end
end

